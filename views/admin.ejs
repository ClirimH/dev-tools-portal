<!DOCTYPE html>
<html>
  <head>
    <title>Dev Tools Landing Page</title>
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body>
    <div class="container">
      <h1>Admin - Manage Links</h1>

      <form class="form" id="link-form">
        <input type="text" id="title" placeholder="Title" required />
        <input type="text" id="url" placeholder="URL" required />
        <input type="text" id="icon" placeholder="Icon URL (optional)" />
        <button type="submit">Add Link</button>
      </form>

      <div id="admin-links" class="grid"></div>

      <script>
        async function loadAdminLinks() {
          const res = await fetch('/api/links');
          const links = await res.json();

          const container = document.getElementById('admin-links');
          container.innerHTML = '';

          links.forEach((link) => {
            const div = document.createElement('div');
            div.className = 'card';

            div.innerHTML = `
      <h3>${link.title}</h3>
      <button onclick="deleteLink('${link._id}')">Delete</button>
    `;

            container.appendChild(div);
          });
        }

        async function deleteLink(id) {
          await fetch('/api/links/' + id, { method: 'DELETE' });
          loadAdminLinks();
        }

        document
          .getElementById('link-form')
          .addEventListener('submit', async (e) => {
            e.preventDefault();

            const title = document.getElementById('title').value;
            const url = document.getElementById('url').value;
            const icon = document.getElementById('icon').value;

            await fetch('/api/links', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ title, url, icon }),
            });

            e.target.reset();
            loadAdminLinks();
          });

        window.onload = loadAdminLinks;
      </script>
    </div>
  </body>
</html>
